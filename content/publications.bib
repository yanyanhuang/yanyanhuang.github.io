@inproceedings{chen2026bridging,
  title={Bridging Radiology and Pathology Foundation Models via Concept-Based Multimodal Co-Adaptation},
  author={Chen, Yihang and Huang, Yanyan and Zhao, Weiqin and Qian, Fangji and Wang, Fuying and Huang, Peixiang and Fu, Yu and Wu, Feng and Liang, Li and Yu, Lequan},
  booktitle={International Conference on Learning Representations (ICLR)},
  year={2026},
  month=mar,
  url={https://openreview.net/forum?id=oxgcPoDkNv},
  pub_type={conference},
  abstract={While radiological and pathology foundation models show promising potential in healthcare, they suffer from shortcut learning due to scanner-specific and domain-specific artifacts. This limits cross-domain generalization and can create demographic bias in prediction. We propose Concept Tuning and Fusing (CTF), a multimodal co-adaptation framework that uses concept-guided visual and textual prompts from both radiology and pathology domains to remove shortcut signals and improve robust representation learning. Across multiple pathology and radiology tasks, CTF improves in-domain and out-of-domain performance while reducing fairness gaps across demographic groups.},
  description={This work introduces a concept-based multimodal co-adaptation framework that bridges radiology and pathology foundation models to improve cross-domain generalization and demographic fairness in medical image analysis.},
  keywords={Medical Image Analysis, Foundation Model Adaptation, Multimodal Learning, Domain Generalization, Fairness}
}

@article{qian2026fadfnet,
  title={FADFNet: A Fine-tunable and Adaptive Decomposition-Fusion Network for Cross-dataset Low-dose CT and Low-dose PET Image Reconstruction},
  author={Qian, Fangji and Wang, Weitao and Huang, Yanyan and Niu, Meng and Gao, Yuanxue and Zhao, Zihao and Shi, Kuangyu and Yu, Lequan and Fu, Yu and Zhuo, Cheng},
